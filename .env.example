# Локальная разработка: скопируйте в .env

NODE_ENV=development
PORT=3000
SESSION_SECRET=замените-на-длинную-случайную-строку

# GigaChat (по желанию): https://developers.sber.ru/studio/workspaces
GIGACHAT_CLIENT_ID=ваш-client-id
GIGACHAT_SECRET_KEY=ваш-ключ-авторизации
GIGACHAT_SCOPE=GIGACHAT_API_B2B
GIGACHAT_MODEL=GigaChat

# Папка для SQLite и загрузок (локально)
DATABASE_DIR=./data
